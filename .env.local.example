# ── Data source ──────────────────────────────────────────────────────────────
# "mock"   → uses catalog-data.ts in-memory (Phase 1–3 behaviour, no backend needed)
# "medusa" → uses Medusa v2 backend at MEDUSA_BACKEND_URL
DATA_SOURCE=mock
NEXT_PUBLIC_DATA_SOURCE=mock

# ── Medusa backend (set these when DATA_SOURCE=medusa) ────────────────────────
# Server-side (not exposed to browser — use for SSR product fetches)
MEDUSA_BACKEND_URL=http://localhost:9000

# Client-side (prefixed NEXT_PUBLIC_ so the browser can reach the backend)
NEXT_PUBLIC_MEDUSA_BACKEND_URL=http://localhost:9000

# Publishable API key — generated by Medusa after setup.
# Found in Medusa admin → Settings → Publishable API Keys.
NEXT_PUBLIC_MEDUSA_PUBLISHABLE_KEY=pk_REPLACE_WITH_YOUR_KEY

# ── Stripe (client-side publishable key only — secret key goes in the backend) ─
# Found in Stripe Dashboard → Developers → API Keys
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_REPLACE_WITH_YOUR_KEY
